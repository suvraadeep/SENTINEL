# SENTINEL environment variables
# Copy this file to .env and fill in your values

# Optional: pre-seed a default provider (user can override in the UI)
DEFAULT_PROVIDER=openai
DEFAULT_MAIN_MODEL=gpt-4o
DEFAULT_FAST_MODEL=gpt-4o-mini

# Optional: pre-seed API key (not recommended for production)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# NVIDIA_API_KEY=nvapi-...

# Server settings
HOST=0.0.0.0
PORT=8000
