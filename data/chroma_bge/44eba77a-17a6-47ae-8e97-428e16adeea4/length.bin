{"chroma:document":"customer cohort retention","description":"Customer cohort retention analysis","sql_template":"WITH first_order AS (SELECT customer_id, MIN(order_date) AS cohort_date FROM orders GROUP BY customer_id) SELECT f.cohort_date, o.order_date, COUNT(DISTINCT o.customer_id) AS retained FROM orders o JOIN first_order f ON o.customer_id=f.customer_id GROUP BY f.cohort_date, o.order_date"}